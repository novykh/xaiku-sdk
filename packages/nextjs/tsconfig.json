{
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "./src",
    "allowJs": true,
    "paths": {
      "~/*": ["./src/*"]
    },
    "strict": false,
    "lib": ["esnext"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.js", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "**/*.test.js"]
}
